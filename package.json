{
  "name": "payment-gateway",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@types/bun": "^1.3.14"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo -F web dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "cd apps/server && ./mvnw spring-boot:run",
    "check:server": "cd apps/server && ./mvnw package",
    "test:server": "cd apps/server && ./mvnw test"
  },
  "dependencies": {
    "@payment-gateway/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@payment-gateway/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
